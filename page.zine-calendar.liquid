{% comment %}
  ZINE Calendar Page Template
  使用方法: Shopify管理画面 > テーマ > コードを編集 > templates/page.zine-calendar.liquid を作成
  その後、対象ページのテンプレートを "page.zine-calendar" に変更する
{% endcomment %}

<div class="zine-calendar-page">

  <div class="zine-calendar-header">
    <h1 class="zine-calendar-title">{{ page.title }}</h1>
    {% if page.content != blank %}
      <div class="zine-calendar-description">{{ page.content }}</div>
    {% endif %}
  </div>

  {%- assign calendar_data = shop.metafields.zine_events.calendar.value -%}

  {%- if calendar_data == blank -%}
    <p class="zine-calendar-empty">現在、登録されているイベント情報がありません。</p>
  {%- else -%}
    <p class="zine-calendar-meta">
      最終更新: <span id="zine-updated-at"></span>
    </p>

    <div class="zine-calendar-filters">
      <button class="zine-filter-btn active" data-category="all">すべて</button>
      <button class="zine-filter-btn" data-category="アートブックフェア">アートブックフェア</button>
      <button class="zine-filter-btn" data-category="ZINEフェス">ZINEフェス</button>
      <button class="zine-filter-btn" data-category="文学フリマ">文学フリマ</button>
    </div>

    <div id="zine-calendar-container"></div>
  {%- endif -%}

</div>

<script>
(function() {
  const raw = {{ calendar_data | json }};
  if (!raw || !raw.events) return;

  // 最終更新日を表示
  const updatedEl = document.getElementById('zine-updated-at');
  if (updatedEl && raw.updated_at) {
    const d = new Date(raw.updated_at);
    updatedEl.textContent = d.toLocaleDateString('ja-JP');
  }

  let currentCategory = 'all';

  function render(category) {
    const container = document.getElementById('zine-calendar-container');
    container.innerHTML = '';

    const events = raw.events.filter(e => {
      if (category === 'all') return true;
      return e.category === category;
    });

    if (events.length === 0) {
      container.innerHTML = '<p class="zine-calendar-empty">該当するイベントがありません。</p>';
      return;
    }

    // 月ごとにグループ化
    const grouped = {};
    events.forEach(e => {
      const month = e.date ? e.date.slice(0, 7) : '未定';
      if (!grouped[month]) grouped[month] = [];
      grouped[month].push(e);
    });

    Object.keys(grouped).sort().forEach(month => {
      const section = document.createElement('div');
      section.className = 'zine-month-section';

      let monthLabel = month;
      if (month !== '未定') {
        const [y, m] = month.split('-');
        monthLabel = `${y}年${parseInt(m)}月`;
      }

      section.innerHTML = `<h2 class="zine-month-heading">${monthLabel}</h2>`;

      const list = document.createElement('ul');
      list.className = 'zine-event-list';

      grouped[month].forEach(ev => {
        const li = document.createElement('li');
        li.className = 'zine-event-item';

        // 日付表示
        let dateLabel = ev.date_display || ev.date || '日程未定';

        // カテゴリバッジ
        const badge = `<span class="zine-badge zine-badge--${ev.source}">${ev.category}</span>`;

        li.innerHTML = `
          <div class="zine-event-date">${dateLabel}</div>
          <div class="zine-event-body">
            <a class="zine-event-title" href="${ev.url}" target="_blank" rel="noopener">
              ${ev.title}
            </a>
            <div class="zine-event-meta">
              <span class="zine-event-venue">📍 ${ev.venue}</span>
              ${badge}
            </div>
          </div>
        `;
        list.appendChild(li);
      });

      section.appendChild(list);
      container.appendChild(section);
    });
  }

  // フィルターボタンのイベント
  document.querySelectorAll('.zine-filter-btn').forEach(btn => {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.zine-filter-btn').forEach(b => b.classList.remove('active'));
      this.classList.add('active');
      currentCategory = this.dataset.category;
      render(currentCategory);
    });
  });

  // 初期描画
  render('all');
})();
</script>

<style>
.zine-calendar-page {
  max-width: 800px;
  margin: 0 auto;
  padding: 2rem 1rem;
  font-family: sans-serif;
}
.zine-calendar-header { margin-bottom: 2rem; }
.zine-calendar-title { font-size: 1.6rem; font-weight: bold; margin-bottom: 0.5rem; }
.zine-calendar-meta { font-size: 0.8rem; color: #888; margin-bottom: 1.5rem; }
.zine-calendar-empty { color: #888; }

/* フィルターボタン */
.zine-calendar-filters {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-bottom: 2rem;
}
.zine-filter-btn {
  padding: 0.4rem 1rem;
  border: 1px solid #333;
  background: transparent;
  cursor: pointer;
  font-size: 0.85rem;
  transition: all 0.2s;
}
.zine-filter-btn.active,
.zine-filter-btn:hover {
  background: #333;
  color: #fff;
}

/* 月セクション */
.zine-month-section { margin-bottom: 2.5rem; }
.zine-month-heading {
  font-size: 1.1rem;
  font-weight: bold;
  border-bottom: 2px solid #333;
  padding-bottom: 0.3rem;
  margin-bottom: 1rem;
}

/* イベントリスト */
.zine-event-list { list-style: none; padding: 0; margin: 0; }
.zine-event-item {
  display: flex;
  gap: 1rem;
  padding: 0.8rem 0;
  border-bottom: 1px solid #eee;
}
.zine-event-date {
  font-size: 0.85rem;
  color: #555;
  white-space: nowrap;
  min-width: 110px;
  padding-top: 0.1rem;
}
.zine-event-body { flex: 1; }
.zine-event-title {
  display: block;
  font-weight: bold;
  font-size: 0.95rem;
  color: inherit;
  text-decoration: none;
  margin-bottom: 0.3rem;
}
.zine-event-title:hover { text-decoration: underline; }
.zine-event-meta {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  flex-wrap: wrap;
}
.zine-event-venue { font-size: 0.8rem; color: #666; }

/* バッジ */
.zine-badge {
  font-size: 0.7rem;
  padding: 0.15rem 0.5rem;
  border-radius: 2px;
  background: #eee;
  color: #444;
}
.zine-badge--tabf          { background: #000; color: #fff; }
.zine-badge--bunfree       { background: #e63; color: #fff; }
.zine-badge--mzfest        { background: #36a; color: #fff; }
.zine-badge--zinefes_note  { background: #693; color: #fff; }

@media (max-width: 600px) {
  .zine-event-item { flex-direction: column; gap: 0.3rem; }
  .zine-event-date { min-width: unset; }
}
</style>
